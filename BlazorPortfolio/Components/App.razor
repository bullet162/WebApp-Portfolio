<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0f" />
    <!-- Open Graph / Social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Jherson Aguto" />
    <meta property="og:title" content="Jherson Aguto | Full Stack Developer Portfolio" />
    <meta property="og:description" content="Personal developer portfolio of Jherson Aguto. Full Stack Developer specializing in .NET, Blazor, and Backend Systems." />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Jherson Aguto | Full Stack Developer Portfolio" />
    <meta name="twitter:description" content="Personal developer portfolio of Jherson Aguto. Full Stack Developer specializing in .NET, Blazor, and Backend Systems." />
    <link rel="canonical" href="https://jhersonaguto.dev/" />
    <base href="/" />
    <!-- Preload critical local resources to reduce waterfall depth -->
    <link rel="preload" href="css/portfolio.css" as="style" />
    <link rel="preload" href="_framework/blazor.web.js" as="script" />
    <!-- Preconnect to GitHub avatar CDN so the hero image loads faster -->
    <link rel="preconnect" href="https://avatars.githubusercontent.com" />
    <ResourcePreloader />
    <link rel="stylesheet" href="css/portfolio.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <div id="app-loading" aria-live="polite" aria-label="Loading portfolio">
        <div class="app-loading-inner">
            <div class="app-loading-logo">
                <span class="brand-dot"></span>Jherson Aguto
            </div>
            <div class="app-loading-bar" aria-hidden="true">
                <div class="app-loading-bar-fill"></div>
            </div>
        </div>
    </div>
    <canvas id="night-sky" aria-hidden="true"></canvas>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 8,
                    retryIntervalMilliseconds: 4000
                }
            }
        }).then(function () {
            var loader = document.getElementById('app-loading');
            if (loader) {
                loader.style.opacity = '0';
                loader.style.transition = 'opacity 0.4s ease';
                setTimeout(function () { loader.style.display = 'none'; }, 420);
            }
        });
    </script>
    <script src="js/cache.js" defer></script>
    <script src="js/animations.js" defer></script>
    <script src="js/contrib-graph.js" defer></script>
</body>

</html>
