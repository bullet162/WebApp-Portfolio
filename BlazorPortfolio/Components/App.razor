<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0f" />
    <!-- Open Graph / Social sharing -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Portfolio" />
    <meta property="og:title" content="Developer Portfolio" />
    <meta property="og:description" content="Full Stack Developer · .NET · Blazor · Cloud" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="Developer Portfolio" />
    <meta name="twitter:description" content="Full Stack Developer · .NET · Blazor · Cloud" />
    <base href="/" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
    <ResourcePreloader />
    <link rel="stylesheet" href="css/portfolio.css" />
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <canvas id="night-sky" aria-hidden="true"></canvas>
    <Routes @rendermode="InteractiveServer" />
    <ReconnectModal />
    <script src="_framework/blazor.web.js" autostart="false"></script>
    <script>
        Blazor.start({
            circuit: {
                reconnectionOptions: {
                    maxRetries: 8,
                    retryIntervalMilliseconds: 4000
                }
            }
        });
    </script>
    <script src="js/cache.js" defer></script>
    <script src="js/animations.js" defer></script>
</body>

</html>
