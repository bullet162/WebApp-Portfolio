@inherits LayoutComponentBase
@inject AdminAuthService Auth
@inject NavigationManager Nav

@if (!Auth.IsAuthenticated)
{
    Nav.NavigateTo("/admin/login", forceLoad: false);
}
else
{
    <div class="admin-shell">
        <nav class="admin-sidebar @(sidebarOpen ? "sidebar-open" : "")">
            <div class="admin-sidebar-top">
                <div class="admin-brand">⚙️ CMS</div>
                <button class="sidebar-toggle" @onclick="ToggleSidebar" aria-label="Toggle sidebar">☰</button>
            </div>
            <div class="admin-sidebar-links">
                <NavLink href="/admin" Match="NavLinkMatch.All" @onclick="CloseSidebar">Dashboard</NavLink>
                <NavLink href="/admin/experiences" @onclick="CloseSidebar">Experiences</NavLink>
                <NavLink href="/admin/skills" @onclick="CloseSidebar">Skills</NavLink>
                <NavLink href="/admin/projects" @onclick="CloseSidebar">Projects</NavLink>
                <NavLink href="/admin/messages" @onclick="CloseSidebar">Messages</NavLink>
                <NavLink href="/admin/profile" @onclick="CloseSidebar">Profile</NavLink>
                <NavLink href="/admin/security" @onclick="CloseSidebar">Security</NavLink>
                <button class="logout-btn" @onclick="Logout">Logout</button>
            </div>
        </nav>
        <main class="admin-content">
            @Body
        </main>
    </div>
}

@code {
    bool sidebarOpen;
    void ToggleSidebar() => sidebarOpen = !sidebarOpen;
    void CloseSidebar() => sidebarOpen = false;

    void Logout()
    {
        Auth.Logout();
        Nav.NavigateTo("/admin/login");
    }
}
