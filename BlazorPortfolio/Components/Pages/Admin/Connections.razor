@page "/admin/connections"
@layout AdminLayout
@rendermode InteractiveServer
@inject ContentService Svc
@inject GeminiService Gemini
@inject IConfiguration Config
@inject IJSRuntime JS
@using BlazorPortfolio.Models
@using System.Text.Json

<PageTitle>Collaboration Requests</PageTitle>
<h1>Collaboration Requests</h1>

<div class="tab-bar">
    @foreach (var tab in Tabs)
    {
        <button class="tab-btn @(activeTab == tab.Status ? "tab-active" : "")"
                @onclick="() => SetTab(tab.Status)">
            @tab.Label
            @if (CountFor(tab.Status) > 0)
            {
                <span class="tab-badge">@CountFor(tab.Status)</span>
            }
        </button>
    }
</div>

@{
    var visible = all.Where(r => r.Status == activeTab).ToList();
}

@if (!visible.Any())
{
    <p class="empty-state">No @activeTab.ToString().ToLower() requests.</p>
}
else
{
    <div class="admin-table-wrap">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Email</th>
                    <th>Portfolio</th>
                    <th>Submitted</th>
                    <th>Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var req in visible)
                {
                    <tr>
                        <td>
                            <div style="display:flex; align-items:center; gap:0.5rem">
                                @req.FirstName @req.LastName
                                @if (req.IsFeatured) { <span title="Featured">⭐</span> }
                                @if (req.IsVerified) { <span title="Verified" style="color:var(--success)">✔️</span> }
                            </div>
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(req.Email))
                            {
                                <a href="mailto:@req.Email" style="font-size:0.8rem">@req.Email</a>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>
                            @if (!string.IsNullOrEmpty(req.PortfolioUrl))
                            {
                                <a href="@req.PortfolioUrl" target="_blank" rel="noopener noreferrer">View ↗</a>
                            }
                            else { <span class="text-muted">—</span> }
                        </td>
                        <td>@req.CreatedAt.ToLocalTime().ToString("MMM d, yyyy")</td>
                        <td class="action-cell">
                            <button class="btn-sm" @onclick="() => OpenModal(req)">View</button>
                            @if (activeTab == CollaborationStatus.Pending || activeTab == CollaborationStatus.Flagged)
                            {
                                <button class="btn-sm success" @onclick="() => Approve(req.Id)">Approve</button>
                                <button class="btn-sm danger" @onclick="() => Reject(req.Id)">Reject</button>
                            }
                            @if (activeTab == CollaborationStatus.Pending)
                            {
                                <button class="btn-sm warn" @onclick="() => Flag(req.Id)">Flag</button>
                            }
                            @if (activeTab == CollaborationStatus.Flagged)
                            {
                                <button class="btn-sm" @onclick="() => Restore(req.Id)">Restore</button>
                            }
                            <button class="btn-sm danger" @onclick="() => Delete(req.Id)">Delete</button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@if (selected is not null)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="compact-modal" @onclick:stopPropagation>
            <div class="modal-header">
                <div>
                    <h3 style="margin: 0; font-size: 1.25rem;">Edit Developer Profile</h3>
                    <div style="margin-top: 0.25rem;">
                        <span class="modal-meta" style="font-size: 0.8rem;">Submitted @selected.CreatedAt.ToLocalTime().ToString("MMM d, yyyy h:mm tt")</span>
                        <span class="status-badge status-@selected.Status.ToString().ToLower()" style="font-size: 0.75rem; padding: 0.15rem 0.4rem; margin-left: 0.5rem;">@selected.Status</span>
                    </div>
                </div>
                <button class="modal-close" @onclick="CloseModal">&times;</button>
            </div>
            <div class="modal-body">
                <EditForm Model="selected" OnValidSubmit="SaveSelected">
                    <DataAnnotationsValidator />
                    <ValidationSummary class="validation-summary" />

                    <div class="admin-section" style="margin-bottom: 1rem;">
                        <h4 class="admin-section-title" style="margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; font-size: 1rem;">Basic Profile</h4>
                        <div class="form-row" style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">First Name</label>
                                <InputText @bind-Value="selected.FirstName" class="form-control" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Last Name</label>
                                <InputText @bind-Value="selected.LastName" class="form-control" />
                            </div>
                        </div>
                        <div class="form-row" style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Role Title</label>
                                <InputText @bind-Value="selected.RoleTitle" class="form-control" placeholder="Full Stack Developer" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Tags (Comma separated)</label>
                                <InputText @bind-Value="selected.Tags" class="form-control" placeholder="C#, Blazor, PostgreSQL" />
                            </div>
                        </div>
                        <div class="form-group" style="margin-bottom: 0.5rem;">
                            <label style="font-size: 0.85rem;">Developer Message</label>
                            <InputTextArea @bind-Value="selected.Message" class="form-control" rows="2" placeholder="Message left by the developer" />
                        </div>
                    </div>

                    <div class="admin-section" style="margin-bottom: 1rem;">
                        <h4 class="admin-section-title" style="margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; font-size: 1rem;">Public Links</h4>
                        <div class="form-row" style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Portfolio URL</label>
                                <InputText @bind-Value="selected.PortfolioUrl" class="form-control" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">GitHub URL</label>
                                <InputText @bind-Value="selected.GitHubUrl" class="form-control" />
                            </div>
                        </div>
                        <div class="form-row" style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">LinkedIn URL</label>
                                <InputText @bind-Value="selected.LinkedInUrl" class="form-control" />
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Email (Private)</label>
                                <InputText @bind-Value="selected.Email" class="form-control" disabled="true" />
                            </div>
                        </div>
                    </div>

                    <div class="admin-section" style="margin-bottom: 1rem;">
                        <h4 class="admin-section-title" style="margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; font-size: 1rem;">Network Settings</h4>
                        <div class="form-row" style="display: flex; gap: 1rem; margin-bottom: 0.5rem;">
                            <div class="form-group" style="flex: 2;">
                                <label style="font-size: 0.85rem;">Public Slug</label>
                                <div style="display:flex; gap:0.5rem">
                                    <InputText @bind-Value="selected.PublicSlug" class="form-control" placeholder="jane-doe" />
                                    <button type="button" class="btn-secondary" @onclick="RegenerateSlug" style="white-space:nowrap; padding: 0.25rem 0.5rem; font-size: 0.8rem;">Reset</button>
                                </div>
                                <span class="field-hint" style="font-size: 0.75rem;">Used for: /network/@(selected.PublicSlug ?? "slug")</span>
                            </div>
                            <div class="form-group" style="flex: 1;">
                                <label style="font-size: 0.85rem;">Display Order</label>
                                <InputNumber @bind-Value="selected.DisplayOrder" class="form-control" />
                            </div>
                        </div>

                        <div class="checkbox-group" style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.5rem; margin-top: 0.5rem; padding: 0.75rem; background: var(--dark2); border-radius: 6px; font-size: 0.85rem;">
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.IsVisible" />
                                <span>Publicly Visible</span>
                            </label>
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.IsFeatured" />
                                <span>Featured</span>
                            </label>
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.IsVerified" />
                                <span>Verified</span>
                            </label>
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.OpenToCollaborate" />
                                <span>Open to Collab</span>
                            </label>
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.BadgeEnabled" />
                                <span>Badge Enabled</span>
                            </label>
                            <label class="checkbox-label" style="margin: 0;">
                                <InputCheckbox @bind-Value="selected.ReciprocalLinkVerified" />
                                <span>Reciprocal</span>
                            </label>
                        </div>
                    </div>

                    <div class="admin-section" style="margin-bottom: 1rem;">
                        <h4 class="admin-section-title" style="margin-bottom: 0.5rem; border-bottom: 1px solid var(--border); padding-bottom: 0.25rem; font-size: 1rem;">Admin Review</h4>
                        <div class="form-group" style="margin-bottom: 0.5rem;">
                            <label style="font-size: 0.85rem;">Admin/Review Note (Internal only)</label>
                            <InputTextArea @bind-Value="selected.ReviewNote" class="form-control" rows="1" />
                        </div>
                    </div>

                    <div class="admin-section ai-enrichment-panel" style="margin-bottom: 1rem; background: rgba(0, 229, 255, 0.05); border: 1px solid rgba(0, 229, 255, 0.2); border-radius: 8px; padding: 0.75rem;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 0.5rem;">
                            <div style="display: flex; align-items: center; gap: 0.5rem;">
                                <h4 style="margin:0; color: #00e5ff; font-size: 1rem;">✨ AI Suggestions</h4>
                                @if (selected.AiEnrichmentConsent)
                                {
                                    <span class="badge" style="background: var(--success); color: white; font-size: 0.65rem;">Consent Granted</span>
                                }
                                else
                                {
                                    <span class="badge" style="background: var(--danger); color: white; font-size: 0.65rem;">Consent Denied</span>
                                }
                            </div>
                            <div style="display:flex; align-items:center; gap:0.5rem">
                                @if (enrichment?.Status == EnrichmentStatus.Ready)
                                {
                                    <span class="text-sm" title="Confidence Score">Confidence: <strong>@(enrichment.ConfidenceScore * 100)%</strong></span>
                                }
                                <button type="button" class="btn-sm btn-secondary" @onclick="CheckModels" disabled="@isCheckingModels" style="background:transparent; border: 1px solid #00e5ff; color: #00e5ff; padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                    @(isCheckingModels ? "Checking..." : "Models")
                                </button>
                                <button type="button" class="btn-sm" @onclick="GenerateAiEnrichment" disabled="@(!selected.AiEnrichmentConsent || isEnriching)" style="@(!selected.AiEnrichmentConsent ? "opacity: 0.5; cursor: not-allowed;" : ""); padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                    @(isEnriching ? "Enriching..." : "Generate")
                                </button>
                            </div>
                        </div>

                        @if (showDiagnosticPanel)
                        {
                            <div style="background: rgba(255,255,255,0.05); padding: 1rem; border-radius: 4px; margin-bottom: 1rem; font-size: 0.85rem;">
                                <strong>Model Discovery Diagnostics</strong><br/>
                                Preferred Model: @(Config["Gemini:Model"] ?? "gemini-2.5-flash") <br/>
                                Discovery Enabled: @(Config["Gemini:EnableModelDiscovery"] == "true") <br/>
                                Cache Hours: @(Config["Gemini:ModelDiscoveryCacheHours"] ?? "12") <br/>
                                Usable Models Found: @(discoveredModels?.Count ?? 0)<br/>
                                @if(discoveredModels != null && discoveredModels.Any())
                                {
                                    <div style="margin-top:0.5rem; color:var(--text-muted)">
                                        @string.Join(", ", discoveredModels)
                                    </div>
                                }
                            </div>
                        }

                        @if (!selected.AiEnrichmentConsent)
                        {
                            <div class="alert-warn" style="font-size:0.85rem">Developer has NOT granted AI enrichment consent. AI Scraping is disabled.</div>
                        }
                        else if (enrichment == null)
                        {
                            <p class="text-sm text-muted">No AI suggestions generated yet. Click the button to analyze links and bio.</p>
                        }
                        else if (enrichment.Status == EnrichmentStatus.Failed)
                        {
                            <div class="alert-danger" style="font-size:0.85rem">AI failed: @enrichment.ErrorMessage</div>
                        }
                        else if (enrichment.Status == EnrichmentStatus.Ready)
                        {
                            <div class="ai-results" style="font-size: 0.9rem;">
                                <div class="mt-2"><strong>Suggested Headline:</strong> @enrichment.GeneratedHeadline</div>
                                <div class="mt-2"><strong>Suggested Summary:</strong> @enrichment.GeneratedSummary</div>
                                
                                @if (!string.IsNullOrEmpty(enrichment.ErrorMessage))
                                {
                                    <div class="alert-warn mt-2" style="font-size:0.75rem; padding: 0.5rem;">⚠️ @enrichment.ErrorMessage</div>
                                }
                            </div>
                        }
                    </div>

                    <div class="admin-section reciprocal-link-panel" style="background: rgba(124, 111, 255, 0.05); border: 1px solid rgba(124, 111, 255, 0.2); border-radius: 8px; padding: 0.75rem;">
                        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom: 0.5rem;">
                            <h4 style="margin:0; color: #7c6fff; font-size: 1rem;">🔗 Reciprocal Link Verification</h4>
                            <button type="button" class="btn-sm" @onclick="VerifyReciprocalLink" disabled="@(string.IsNullOrEmpty(selected.PortfolioUrl) || isVerifying)" style="padding: 0.25rem 0.5rem; font-size: 0.8rem;">
                                @(isVerifying ? "Verifying..." : "Verify Link")
                            </button>
                        </div>
                        <p style="font-size: 0.85rem; color: var(--text-muted); margin-bottom: 1rem; line-height: 1.5;">
                            Clicking <strong>Verify Link</strong> will scan the developer's Portfolio URL to check if they have embedded your Developer Network Badge linking back to this site. If found, it automatically awards them the <strong>Reciprocal Link Verified</strong> badge.
                        </p>

                        <div class="text-sm" style="font-size: 0.85rem;">
                            <div style="display: flex; gap: 1rem; margin-bottom: 0.25rem;">
                                <div>Status: <strong>@(selected.ReciprocalLinkVerified ? "✅ Verified" : "❌ Not Verified")</strong></div>
                                @if (selected.ReciprocalLinkVerifiedAt.HasValue)
                                {
                                    <div>Verified At: @selected.ReciprocalLinkVerifiedAt.Value.ToLocalTime().ToString("g")</div>
                                }
                            </div>
                            
                            @if (selected.ReciprocalLinkLastCheckedAt.HasValue)
                            {
                                <div class="text-muted">Last Checked: @selected.ReciprocalLinkLastCheckedAt.Value.ToLocalTime().ToString("g")</div>
                            }

                            @if (!string.IsNullOrEmpty(selected.ReciprocalLinkCheckError))
                            {
                                <div class="alert-danger mt-2" style="font-size: 0.8rem; padding: 0.5rem;">
                                    ⚠️ @selected.ReciprocalLinkCheckError
                                </div>
                            }
                            else if (string.IsNullOrEmpty(selected.PortfolioUrl))
                            {
                                <div class="alert-warn mt-2" style="font-size: 0.8rem; padding: 0.5rem;">
                                    No Portfolio URL provided for verification.
                                </div>
                            }
                        </div>
                    </div>

                    <div class="modal-footer" style="padding-top: 1rem;">
                        <div style="flex: 1; text-align: left; font-size: 0.8rem; color: var(--text-muted);">
                            <div>Updated: @selected.UpdatedAt.ToLocalTime().ToString("g")</div>
                        </div>
                        
                        @if (selected.Status != CollaborationStatus.Approved)
                        {
                            <button type="button" class="btn-primary" @onclick="() => ApproveAndClose(selected.Id)">Approve ✅</button>
                        }
                        <button type="submit" class="btn-primary">Save Changes</button>
                        <button type="button" class="btn-secondary" @onclick="CloseModal">Cancel</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

@code {
    record TabDef(string Label, CollaborationStatus Status);
    static readonly TabDef[] Tabs =
    [
        new("Pending",  CollaborationStatus.Pending),
        new("Flagged",  CollaborationStatus.Flagged),
        new("Approved", CollaborationStatus.Approved),
        new("Rejected", CollaborationStatus.Rejected),
    ];

    List<CollaborationRequest> all = [];
    CollaborationStatus activeTab = CollaborationStatus.Pending;
    CollaborationRequest? selected;
    DeveloperProfileEnrichment? enrichment;
    bool isEnriching = false;
    bool isVerifying = false;
    bool isCheckingModels = false;
    bool showDiagnosticPanel = false;
    List<string>? discoveredModels;

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load()
    {
        all = await Svc.GetCollaborationRequestsAsync();
    }

    int CountFor(CollaborationStatus s) => all.Count(r => r.Status == s);
    void SetTab(CollaborationStatus s) => activeTab = s;
    
    async Task OpenModal(CollaborationRequest req)
    {
        selected = req;
        enrichment = await Svc.GetEnrichmentAsync(req.Id);
    }
    
    void CloseModal() { selected = null; enrichment = null; enrichCts?.Cancel(); }

    async Task SaveSelected()
    {
        if (selected == null) return;
        await Svc.UpdateCollaborationRequestAsync(selected);
        selected = null;
        enrichment = null;
        enrichCts?.Cancel();
        await Load();
    }

    CancellationTokenSource? enrichCts;

    async Task GenerateAiEnrichment()
    {
        if (selected == null || isEnriching) return;
        isEnriching = true;
        enrichCts?.Cancel();
        enrichCts = new CancellationTokenSource();
        StateHasChanged();
        try
        {
            await JS.InvokeVoidAsync("console.log", "[AI]: Started enrichment process...");
            var res = await Gemini.EnrichProfileAsync(selected, msg => 
            {
                InvokeAsync(() => JS.InvokeVoidAsync("console.log", $"[AI]: {msg}"));
            });
            
            if (!enrichCts.Token.IsCancellationRequested)
            {
                await Svc.SaveEnrichmentAsync(res);
                enrichment = res;
                await JS.InvokeVoidAsync("console.log", $"[AI]: Enrichment finished with status: {res.Status}");
            }
        }
        catch (OperationCanceledException)
        {
            // User cancelled — that's fine
        }
        finally
        {
            isEnriching = false;
            StateHasChanged();
        }
    }

    async Task CheckModels()
    {
        if (isCheckingModels) return;
        isCheckingModels = true;
        try
        {
            discoveredModels = await Gemini.GetAvailableGenerateContentModelsAsync(forceRefresh: true);
            showDiagnosticPanel = true;
        }
        finally
        {
            isCheckingModels = false;
        }
    }

    async Task VerifyReciprocalLink()
    {
        if (selected == null || isVerifying) return;
        isVerifying = true;
        try
        {
            await Svc.VerifyReciprocalLinkAsync(selected.Id);
            // Refresh local object state
            var updated = all.FirstOrDefault(r => r.Id == selected.Id);
            if (updated != null)
            {
                // We need to re-fetch the specific request or reload all to get updated DB fields
                await Load();
                selected = all.FirstOrDefault(r => r.Id == selected.Id);
            }
        }
        finally
        {
            isVerifying = false;
        }
    }

    void RegenerateSlug()
    {
        if (selected == null) return;
        selected.PublicSlug = null; // Let service regenerate it on save
    }

    async Task Approve(int id) { await Svc.SetCollaborationStatusAsync(id, CollaborationStatus.Approved); await Load(); }
    async Task Reject(int id)  { await Svc.SetCollaborationStatusAsync(id, CollaborationStatus.Rejected); await Load(); }
    async Task Flag(int id)    { await Svc.SetCollaborationStatusAsync(id, CollaborationStatus.Flagged);  await Load(); }
    async Task Restore(int id) { await Svc.SetCollaborationStatusAsync(id, CollaborationStatus.Pending);  await Load(); }
    async Task Delete(int id)  { await Svc.DeleteCollaborationRequestAsync(id); await Load(); }

    async Task ApproveAndClose(int id) { await Approve(id); selected = null; }
    async Task RejectAndClose(int id)  { await Reject(id);  selected = null; }
}
