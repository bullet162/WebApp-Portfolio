@page "/admin/experiences"
@layout AdminLayout
@rendermode InteractiveServer
@inject ContentService Svc

<PageTitle>Manage Experiences</PageTitle>
<h1>Experiences</h1>

<button class="btn-primary" @onclick="AddNew">+ Add Experience</button>

@if (editing is not null)
{
    <div class="edit-form">
        <h3>@(editing.Id == 0 ? "New" : "Edit") Experience</h3>
        <EditForm Model="editing" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Title</label>
                <InputText @bind-Value="editing.Title" class="form-control" />
            </div>
            <div class="form-group">
                <label>Company</label>
                <InputText @bind-Value="editing.Company" class="form-control" />
            </div>
            <div class="form-group">
                <label>Period (e.g. 2020 - 2023)</label>
                <InputText @bind-Value="editing.Period" class="form-control" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <InputTextArea @bind-Value="editing.Description" class="form-control" rows="3" />
            </div>
            <div class="form-group">
                <label>Sort Order</label>
                <InputNumber @bind-Value="editing.SortOrder" class="form-control" />
            </div>
            <button type="submit" class="btn-primary">Save</button>
            <button type="button" class="btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </div>
}

<table class="admin-table">
    <thead>
        <tr><th>Title</th><th>Company</th><th>Period</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var exp in items)
        {
            <tr>
                <td>@exp.Title</td>
                <td>@exp.Company</td>
                <td>@exp.Period</td>
                <td>
                    <button class="btn-sm" @onclick="() => Edit(exp)">Edit</button>
                    <button class="btn-sm danger" @onclick="() => Delete(exp.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    List<Experience> items = [];
    Experience? editing;

    protected override async Task OnInitializedAsync() => await Load();

    async Task Load() => items = await Svc.GetExperiencesAsync();

    void AddNew() => editing = new();
    void Edit(Experience exp) => editing = new Experience
    {
        Id = exp.Id, Title = exp.Title, Company = exp.Company,
        Period = exp.Period, Description = exp.Description, SortOrder = exp.SortOrder
    };
    void Cancel() => editing = null;

    async Task Save()
    {
        await Svc.SaveExperienceAsync(editing!);
        editing = null;
        await Load();
    }

    async Task Delete(int id)
    {
        await Svc.DeleteExperienceAsync(id);
        await Load();
    }
}
