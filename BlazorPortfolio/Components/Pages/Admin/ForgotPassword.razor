@page "/admin/forgot-password"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject EmailService EmailSvc
@inject NavigationManager Nav

<PageTitle>Forgot Password</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h2>Forgot Password</h2>
        <p style="opacity:.7;font-size:.9rem">Enter your admin email and we'll send a reset link.</p>

        @if (sent)
        {
            <div class="alert-success">If that email exists, a reset link has been sent. Check your inbox.</div>
            <a href="/admin/login" style="display:block;margin-top:1rem;text-align:center">Back to Login</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert-error">@error</div>
            }
            <EditForm Model="model" OnValidSubmit="Submit">
                <div class="form-group">
                    <label>Email</label>
                    <InputText @bind-Value="model.Email" type="email" class="form-control" />
                </div>
                <button type="submit" class="btn-primary" style="width:100%" disabled="@loading">
                    @(loading ? "Sending..." : "Send Reset Link")
                </button>
            </EditForm>
            <a href="/admin/login" style="display:block;margin-top:1rem;text-align:center;opacity:.6">Back to Login</a>
        }
    </div>
</div>

@code {
    ForgotModel model = new();
    bool sent, loading;
    string? error;

    async Task Submit()
    {
        loading = true;
        error = null;
        try
        {
            await using var db = await DbFactory.CreateDbContextAsync();
            var user = await db.AdminUsers.FirstOrDefaultAsync(u => u.Email == model.Email);

            if (user is not null)
            {
                // Invalidate any existing unused tokens
                var old = db.PasswordResetTokens.Where(t => t.AdminUserId == user.Id && !t.Used);
                db.PasswordResetTokens.RemoveRange(old);

                var token = new PasswordResetToken
                {
                    AdminUserId = user.Id,
                    Token = Convert.ToBase64String(System.Security.Cryptography.RandomNumberGenerator.GetBytes(32)),
                    ExpiresAt = DateTime.UtcNow.AddMinutes(30),
                    Used = false
                };
                db.PasswordResetTokens.Add(token);
                await db.SaveChangesAsync();

                var link = Nav.ToAbsoluteUri($"/admin/reset-password/{Uri.EscapeDataString(token.Token)}").ToString();
                await EmailSvc.SendPasswordResetAsync(user.Email, link);
            }

            // Always show success to avoid email enumeration
            sent = true;
        }
        catch (Exception ex)
        {
            error = $"Failed to send email: {ex.Message}";
        }
        loading = false;
    }

    class ForgotModel
    {
        public string Email { get; set; } = string.Empty;
    }
}
