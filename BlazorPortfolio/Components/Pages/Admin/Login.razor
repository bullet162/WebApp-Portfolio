@page "/admin/login"
@inject AdminAuthService Auth
@inject NavigationManager Nav

<PageTitle>Admin Login</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h2>Admin Login</h2>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert-error">@error</div>
        }
        <EditForm Model="model" OnValidSubmit="DoLogin">
            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="model.Username" class="form-control" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="model.Password" type="password" class="form-control" />
            </div>
            <button type="submit" class="btn-primary" style="width:100%" disabled="@loading">
                @(loading ? "Logging in..." : "Login")
            </button>
        </EditForm>
        <a href="/admin/forgot-password" style="display:block;margin-top:1rem;text-align:center;opacity:.6">Forgot password?</a>
    </div>
</div>

@code {
    LoginModel model = new();
    string? error;
    bool loading;

    async Task DoLogin()
    {
        loading = true;
        error = null;
        if (await Auth.LoginAsync(model.Username, model.Password))
            Nav.NavigateTo("/admin");
        else
            error = "Invalid credentials.";
        loading = false;
    }

    class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
