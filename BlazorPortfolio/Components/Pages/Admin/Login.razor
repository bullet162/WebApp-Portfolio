@page "/admin/login"
@rendermode InteractiveServer
@inject AdminAuthService Auth
@inject NavigationManager Nav
@inject IJSRuntime JS

<PageTitle>Admin Login</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h2>Admin Login</h2>
        @if (!string.IsNullOrEmpty(error))
        {
            <div class="alert-error">@error</div>
        }
        <EditForm Model="model" OnValidSubmit="DoLogin">
            <div class="form-group">
                <label>Username</label>
                <InputText @bind-Value="model.Username" class="form-control" />
            </div>
            <div class="form-group">
                <label>Password</label>
                <InputText @bind-Value="model.Password" type="password" class="form-control" />
            </div>
            <div class="form-group" style="margin-bottom: 1.5rem; display: flex; align-items: center; gap: 0.5rem;">
                <InputCheckbox @bind-Value="model.RememberMe" id="rememberMe" />
                <label for="rememberMe" style="margin-bottom: 0; cursor: pointer; font-size: 0.9rem; opacity: 0.8;">Remember this device</label>
            </div>
            <button type="submit" class="btn-primary" style="width:100%" disabled="@(loading || lockedOut)">
                @(loading ? "Logging in..." : "Login")
            </button>
        </EditForm>
        <a href="/admin/forgot-password" style="display:block;margin-top:1rem;text-align:center;opacity:.6">Forgot password?</a>
    </div>
</div>

@code {
    LoginModel model = new();
    string? error;
    bool loading;
    bool lockedOut;

    // Use a stable per-session key — circuit ID would be ideal but username is fine
    private string AttemptKey => "login";

    protected override void OnInitialized()
    {
        if (Auth.IsLockedOut(AttemptKey))
        {
            var remaining = Auth.LockoutRemaining(AttemptKey);
            error = $"Too many failed attempts. Try again in {(int)remaining.TotalSeconds}s.";
            lockedOut = true;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && !Auth.IsAuthenticated)
        {
            try 
            {
                var token = await JS.InvokeAsync<string?>("localStorage.getItem", "admin_auth_token");
                if (!string.IsNullOrEmpty(token))
                {
                    if (await Auth.TryAutoLoginAsync(token))
                    {
                        StateHasChanged();
                        Nav.NavigateTo("/admin");
                    }
                }
            }
            catch { /* Ignore JS errors during pre-rendering */ }
        }
    }

    async Task DoLogin()
    {
        if (Auth.IsLockedOut(AttemptKey))
        {
            var remaining = Auth.LockoutRemaining(AttemptKey);
            error = $"Too many failed attempts. Try again in {(int)remaining.TotalSeconds}s.";
            lockedOut = true;
            return;
        }

        loading = true;
        error = null;

        var result = await Auth.LoginAsync(model.Username, model.Password, model.RememberMe, AttemptKey);
        
        if (result.success)
        {
            if (model.RememberMe && !string.IsNullOrEmpty(result.token))
            {
                await JS.InvokeVoidAsync("localStorage.setItem", "admin_auth_token", result.token);
            }
            Nav.NavigateTo("/admin");
        }
        else
        {
            if (Auth.IsLockedOut(AttemptKey))
            {
                error = "Too many failed attempts. Please wait 1 minute before trying again.";
                lockedOut = true;
            }
            else
                error = "Invalid credentials.";
        }

        loading = false;
    }

    class LoginModel
    {
        public string Username { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
        public bool RememberMe { get; set; }
    }
}
