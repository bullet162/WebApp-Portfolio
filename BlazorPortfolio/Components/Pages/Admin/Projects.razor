@page "/admin/projects"
@layout AdminLayout
@rendermode InteractiveServer
@inject ContentService Svc

<PageTitle>Manage Projects</PageTitle>
<h1>Projects</h1>

<button class="btn-primary" @onclick="AddNew">+ Add Project</button>

@if (editing is not null)
{
    <div class="edit-form">
        <h3>@(editing.Id == 0 ? "New" : "Edit") Project</h3>
        <EditForm Model="editing" OnValidSubmit="Save">
            <DataAnnotationsValidator />
            <div class="form-group">
                <label>Title</label>
                <InputText @bind-Value="editing.Title" class="form-control" />
            </div>
            <div class="form-group">
                <label>Description</label>
                <InputTextArea @bind-Value="editing.Description" class="form-control" rows="3" />
            </div>
            <div class="form-group">
                <label>Tech Stack</label>
                <InputText @bind-Value="editing.TechStack" class="form-control" placeholder="e.g. Blazor, EF Core, SQLite" />
            </div>
            <div class="form-group">
                <label>Live URL (optional)</label>
                <InputText @bind-Value="editing.LiveUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>Repo URL (optional)</label>
                <InputText @bind-Value="editing.RepoUrl" class="form-control" />
            </div>
            <div class="form-group">
                <label>Sort Order</label>
                <InputNumber @bind-Value="editing.SortOrder" class="form-control" />
            </div>
            <button type="submit" class="btn-primary">Save</button>
            <button type="button" class="btn-secondary" @onclick="Cancel">Cancel</button>
        </EditForm>
    </div>
}

<table class="admin-table">
    <thead>
        <tr><th>Title</th><th>Tech Stack</th><th>Actions</th></tr>
    </thead>
    <tbody>
        @foreach (var proj in items)
        {
            <tr>
                <td>@proj.Title</td>
                <td>@proj.TechStack</td>
                <td>
                    <button class="btn-sm" @onclick="() => Edit(proj)">Edit</button>
                    <button class="btn-sm danger" @onclick="() => Delete(proj.Id)">Delete</button>
                </td>
            </tr>
        }
    </tbody>
</table>

@code {
    List<Project> items = [];
    Project? editing;

    protected override async Task OnInitializedAsync() => await Load();
    async Task Load() => items = await Svc.GetProjectsAsync();

    void AddNew() => editing = new();
    void Edit(Project p) => editing = new Project
    {
        Id = p.Id, Title = p.Title, Description = p.Description,
        TechStack = p.TechStack, LiveUrl = p.LiveUrl, RepoUrl = p.RepoUrl, SortOrder = p.SortOrder
    };
    void Cancel() => editing = null;

    async Task Save()
    {
        await Svc.SaveProjectAsync(editing!);
        editing = null;
        await Load();
    }

    async Task Delete(int id)
    {
        await Svc.DeleteProjectAsync(id);
        await Load();
    }
}
