@page "/admin/reset-password/{token}"
@inject IDbContextFactory<AppDbContext> DbFactory
@inject NavigationManager Nav

<PageTitle>Reset Password</PageTitle>

<div class="login-wrapper">
    <div class="login-card">
        <h2>Reset Password</h2>

        @if (invalid)
        {
            <div class="alert-error">This reset link is invalid or has expired.</div>
            <a href="/admin/forgot-password" style="display:block;margin-top:1rem;text-align:center">Request a new link</a>
        }
        else if (done)
        {
            <div class="alert-success">Password updated. You can now log in.</div>
            <a href="/admin/login" style="display:block;margin-top:1rem;text-align:center">Go to Login</a>
        }
        else
        {
            @if (!string.IsNullOrEmpty(error))
            {
                <div class="alert-error">@error</div>
            }
            <EditForm Model="model" OnValidSubmit="Submit">
                <div class="form-group">
                    <label>New Password</label>
                    <InputText @bind-Value="model.NewPassword" type="password" class="form-control" />
                </div>
                <div class="form-group">
                    <label>Confirm Password</label>
                    <InputText @bind-Value="model.ConfirmPassword" type="password" class="form-control" />
                </div>
                <button type="submit" class="btn-primary" style="width:100%" disabled="@loading">
                    @(loading ? "Saving..." : "Reset Password")
                </button>
            </EditForm>
        }
    </div>
</div>

@code {
    [Parameter] public string Token { get; set; } = string.Empty;

    ResetModel model = new();
    bool invalid, done, loading;
    string? error;

    protected override async Task OnInitializedAsync()
    {
        await using var db = await DbFactory.CreateDbContextAsync();
        var tokenRecord = await db.PasswordResetTokens
            .FirstOrDefaultAsync(t => t.Token == Token && !t.Used && t.ExpiresAt > DateTime.UtcNow);
        if (tokenRecord is null) invalid = true;
    }

    async Task Submit()
    {
        if (model.NewPassword != model.ConfirmPassword)
        {
            error = "Passwords do not match.";
            return;
        }
        if (model.NewPassword.Length < 8)
        {
            error = "Password must be at least 8 characters.";
            return;
        }

        loading = true;
        error = null;

        await using var db = await DbFactory.CreateDbContextAsync();
        var tokenRecord = await db.PasswordResetTokens
            .FirstOrDefaultAsync(t => t.Token == Token && !t.Used && t.ExpiresAt > DateTime.UtcNow);

        if (tokenRecord is null) { invalid = true; return; }

        var user = await db.AdminUsers.FindAsync(tokenRecord.AdminUserId);
        if (user is null) { invalid = true; return; }

        user.PasswordHash = BCrypt.Net.BCrypt.HashPassword(model.NewPassword);
        tokenRecord.Used = true;
        await db.SaveChangesAsync();

        done = true;
        loading = false;
    }

    class ResetModel
    {
        public string NewPassword { get; set; } = string.Empty;
        public string ConfirmPassword { get; set; } = string.Empty;
    }
}
