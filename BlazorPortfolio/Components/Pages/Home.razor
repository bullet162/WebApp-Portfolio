@code {
    List<Experience>? experiences;
    List<Skill>? skills;
    List<Project>? projects;
    SiteProfile? profile;
    HiringMessage hiringMsg = new();
    bool messageSent;
    CollaborationRequest collabReq = new();
    bool collabSent;
    List<CollaborationRequest>? approvedCollaborators;
    CollaborationRequest? selectedPeer;
    void OpenPeerModal(CollaborationRequest peer) => selectedPeer = peer;
    void ClosePeerModal() => selectedPeer = null;

    GitHubProfile? ghProfile;
    List<GitHubPinnedRepo>? pinnedRepos;
    List<GitHubPinnedRepo>? allRepos;
    List<GitHubContributionWeek>? ghContribWeeks;
    int ghContribTotal;
    int longestStreak;
    int currentStreak;
    List<(string Label, int Col)> monthLabels = [];
    string repoTab = "pinned";
    List<ConstellationSystem> constellations = [];
    string activeSystem = "";

    void SetSystem(string name) { activeSystem = name; }

    record ConstellationNode(string Name, double X, double Y, int Size, int Index, string LabelDir);
    record ConstellationEdge(int A, int B, double Weight);
    record ConstellationSystem(string Name, string Color, List<ConstellationNode> Nodes, List<ConstellationEdge> Edges);

    protected override async Task OnInitializedAsync()
    {
        // Load all portfolio DB data in parallel — cache hit = near-instant
        var profileTask      = Cache.GetAsync<SiteProfile>(CacheService.Keys.Profile);
        var experiencesTask  = Cache.GetAsync<List<Experience>>(CacheService.Keys.Experiences);
        var skillsTask       = Cache.GetAsync<List<Skill>>(CacheService.Keys.Skills);
        var projectsTask     = Cache.GetAsync<List<Project>>(CacheService.Keys.Projects);
        var collabTask       = Cache.GetAsync<List<CollaborationRequest>>(CacheService.Keys.Collaborators);

        await Task.WhenAll(profileTask, experiencesTask, skillsTask, projectsTask, collabTask);

        profile     = profileTask.Result     ?? await FetchAndCache(Svc.GetProfileAsync(),        CacheService.Keys.Profile);
        experiences = experiencesTask.Result ?? await FetchAndCache(Svc.GetExperiencesAsync(),    CacheService.Keys.Experiences);
        skills      = skillsTask.Result      ?? await FetchAndCache(Svc.GetSkillsAsync(),         CacheService.Keys.Skills);
        projects    = projectsTask.Result    ?? await FetchAndCache(Svc.GetProjectsAsync(),       CacheService.Keys.Projects);
        approvedCollaborators = collabTask.Result ?? await FetchAndCache(Svc.GetApprovedCollaboratorsAsync(), CacheService.Keys.Collaborators);

        BuildConstellation();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;

        if (!string.IsNullOrWhiteSpace(profile?.GitHubUsername))
        {
            var username = profile.GitHubUsername;

            // Check cache for all GitHub data at once
            var ghProfileTask = Cache.GetAsync<GitHubProfile>(CacheService.Keys.GitHubProfile);
            var pinnedTask    = Cache.GetAsync<List<GitHubPinnedRepo>>(CacheService.Keys.GitHubPinned);
            var contribTask   = Cache.GetAsync<List<GitHubContributionWeek>>(CacheService.Keys.GitHubContributions);
            var contribTotTask = Cache.GetAsync<int>(CacheService.Keys.GitHubContribTotal);

            await Task.WhenAll(ghProfileTask, pinnedTask, contribTask, contribTotTask);

            ghProfile      = ghProfileTask.Result;
            pinnedRepos    = pinnedTask.Result;
            ghContribWeeks = contribTask.Result;
            ghContribTotal = contribTotTask.Result;

            // Fetch anything not in cache — profile + pinned in parallel
            var needGhProfile = ghProfile is null;
            var needPinned    = pinnedRepos is null;
            var needContrib   = ghContribWeeks is null;

            if (needGhProfile || needPinned)
            {
                var fetchTasks = new List<Task>();
                Task<GitHubProfile?>? fetchGhProfile = null;
                Task<List<GitHubPinnedRepo>>? fetchPinned = null;

                if (needGhProfile) fetchTasks.Add(fetchGhProfile = GitHub.GetProfileAsync(username));
                if (needPinned)    fetchTasks.Add(fetchPinned    = GitHub.GetPinnedReposAsync(username));

                await Task.WhenAll(fetchTasks);

                if (fetchGhProfile is not null)
                {
                    ghProfile = await fetchGhProfile;
                    if (ghProfile is not null) await Cache.SetAsync(CacheService.Keys.GitHubProfile, ghProfile);
                }
                if (fetchPinned is not null)
                {
                    pinnedRepos = await fetchPinned ?? [];
                    await Cache.SetAsync(CacheService.Keys.GitHubPinned, pinnedRepos);
                }
            }

            pinnedRepos ??= [];
            StateHasChanged();

            // All repos — lazy load (only shown on tab switch, lower priority)
            allRepos = await Cache.GetAsync<List<GitHubPinnedRepo>>(CacheService.Keys.GitHubAllRepos)
                       ?? await FetchAndCache(GitHub.GetAllPublicReposAsync(username), CacheService.Keys.GitHubAllRepos);
            allRepos ??= [];
            StateHasChanged();

            if (needContrib)
            {
                var (weeks, total) = await GitHub.GetContributionsAsync(username);
                ghContribWeeks = weeks; ghContribTotal = total;
                await Cache.SetAsync(CacheService.Keys.GitHubContributions, weeks);
                await Cache.SetAsync(CacheService.Keys.GitHubContribTotal,  total);
            }
            if (ghContribWeeks is { Count: > 0 }) { ComputeStreaks(); BuildMonthLabels(); }
            StateHasChanged();
        }
        else
        {
            pinnedRepos = [];
            allRepos    = [];
        }
    }

    void SetTab(string tab) => repoTab = tab;

    void BuildConstellation()
    {
        var allSkills = (skills ?? []).ToList();
        if (allSkills.Count == 0) return;

        // Define systems — groups of related skill name keywords
        // Each system has a name, color, and keyword matchers
        var systemDefs = new List<(string Name, string Color, string[] Keywords)>
        {
            ("Web API",       "#00e5ff", new[]{"asp.net","web api","restful","swagger","http","endpoint","api","controller"}),
            ("Data & Math",   "#ffd166", new[]{"sql","linq","entity framework","orm","data","algorithm","mathematical","time series","forecasting","modeling","mining"}),
            ("C# Core",       "#a29bfe", new[]{"c#","async","await","multithreading","task","parallelism","file i/o","blazor","fundamentals"}),
            ("Frontend",      "#fd79a8", new[]{"javascript","html","css","blazor","frontend","ui","web"}),
            ("DevOps & Tools",  "#74b9ff", new[]{"git","version control","docker","ci","cd","devops","azure","cloud","deploy"}),
        };

        // Assign each skill to the best matching system
        var buckets = systemDefs.Select(s => (s.Name, s.Color, Items: new List<Skill>())).ToList();

        foreach (var skill in allSkills)
        {
            var lower = skill.Name.ToLowerInvariant();
            int bestIdx = -1; int bestScore = 0;
            for (int si = 0; si < systemDefs.Count; si++)
            {
                int score = systemDefs[si].Keywords.Count(kw => lower.Contains(kw));
                if (score > bestScore) { bestScore = score; bestIdx = si; }
            }
            // fallback: match by category name
            if (bestIdx < 0)
            {
                var catLower = skill.Category.ToLowerInvariant();
                for (int si = 0; si < systemDefs.Count; si++)
                {
                    if (systemDefs[si].Keywords.Any(kw => catLower.Contains(kw))) { bestIdx = si; break; }
                }
            }
            if (bestIdx < 0) bestIdx = 0; // default to first system
            buckets[bestIdx].Items.Add(skill);
        }

        // Remove empty systems
        buckets = buckets.Where(b => b.Items.Count > 0).ToList();
        if (buckets.Count == 0) return;

        int maxProf = allSkills.Max(s => s.Proficiency);

        constellations = buckets.Select(bucket =>
        {
            var items = bucket.Items;
            int n = items.Count;
            var nodes = new List<ConstellationNode>();

            // Lay out nodes in a circle with enough radius to avoid label overlap
            // More nodes = bigger radius
            double baseR = n <= 3 ? 22 : n <= 6 ? 28 : n <= 10 ? 33 : 38;
            double cx = 50, cy = 50;

            for (int i = 0; i < n; i++)
            {
                double angle = (2 * Math.PI * i / n) - Math.PI / 2;
                double x = Math.Round(cx + baseR * Math.Cos(angle), 1);
                double y = Math.Round(cy + baseR * Math.Sin(angle) * 0.75, 1); // slightly squished vertically
                int sz = (int)(8 + 14 * ((double)items[i].Proficiency / maxProf));

                // Label direction: push label away from center
                string dir = angle switch {
                    var a when Math.Cos(a) > 0.5  => "cn-label-right",
                    var a when Math.Cos(a) < -0.5 => "cn-label-left",
                    var a when Math.Sin(a) > 0     => "cn-label-below",
                    _                              => ""
                };

                nodes.Add(new ConstellationNode(items[i].Name, x, y, sz, i, dir));
            }

            // Connect every node to every other in the same system (full constellation)
            var edges = new List<ConstellationEdge>();
            for (int i = 0; i < n; i++)
                for (int j = i + 1; j < n; j++)
                    edges.Add(new ConstellationEdge(i, j, 0.7));

            return new ConstellationSystem(bucket.Name, bucket.Color, nodes, edges);
        }).ToList();

        if (!constellations.Any(c => c.Name == activeSystem))
            activeSystem = constellations[0].Name;
    }

    void ComputeStreaks() {
        var days = ghContribWeeks!.SelectMany(w => w.Days).OrderBy(d => d.Date).ToList();
        int run=0, lng=0, cur=0; var today = DateTime.UtcNow.Date;
        foreach (var d in days) { if (d.Count>0) run++; else run=0; if (run>lng) lng=run; }
        foreach (var d in days.AsEnumerable().Reverse()) {
            if (!DateTime.TryParse(d.Date, out var dt)) break;
            if (dt.Date > today) continue;
            if (d.Count > 0) cur++; else break;
        }
        longestStreak = lng; currentStreak = cur;
    }

    void BuildMonthLabels() {
        monthLabels = []; string? last = null; int col = 1;
        foreach (var week in ghContribWeeks!) {
            var first = week.Days.FirstOrDefault();
            if (first is not null && DateTime.TryParse(first.Date, out var dt)) {
                var m = dt.ToString("MMM");
                if (m != last) { monthLabels.Add((m, col)); last = m; }
            }
            col++;
        }
    }

    async Task<T> FetchAndCache<T>(Task<T> task, string key) {
        var d = await task; await Cache.SetAsync(key, d); return d;
    }

    async Task SendMessage() {
        hiringMsg.SentAt = DateTime.UtcNow;
        await Svc.AddMessageAsync(hiringMsg);
        messageSent = true; hiringMsg = new();
    }

    async Task SendCollabRequest() {
        await Svc.AddCollaborationRequestAsync(collabReq);
        collabSent = true; collabReq = new();
    }

    static string GetInitials(string? name) {
        if (string.IsNullOrWhiteSpace(name)) return "YN";
        var p = name.Trim().Split(' ', StringSplitOptions.RemoveEmptyEntries);
        return p.Length >= 2 ? $"{p[0][0]}{p[^1][0]}".ToUpper() : name[..Math.Min(2,name.Length)].ToUpper();
    }

    static string TimeAgo(DateTime dt) {
        var d = DateTime.UtcNow - dt;
        if (d.TotalDays < 1) return "today";
        if (d.TotalDays < 7) return $"{(int)d.TotalDays}d ago";
        if (d.TotalDays < 30) return $"{(int)(d.TotalDays/7)}w ago";
        if (d.TotalDays < 365) return $"{(int)(d.TotalDays/30)}mo ago";
        return $"{(int)(d.TotalDays/365)}y ago";
    }
}
