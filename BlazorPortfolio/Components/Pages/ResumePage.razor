@page "/resume"
@rendermode InteractiveServer
@inject ContentService Svc
@inject IJSRuntime JS

<PageTitle>Jherson Aguto | Professional Resume</PageTitle>

<HeadContent>
    <meta name="description" content="View and download the professional resume of Jherson Aguto, Full Stack Developer specializing in .NET Core, Blazor, and high-performance backend systems." />
    <meta property="og:title" content="Jherson Aguto | Professional Resume" />
    <meta property="og:description" content="View and download the professional resume of Jherson Aguto, Full Stack Developer." />
    <meta name="twitter:title" content="Jherson Aguto | Professional Resume" />
    <meta name="twitter:description" content="View and download the professional resume of Jherson Aguto, Full Stack Developer." />
</HeadContent>

<div class="resume-page-container">
    <div class="resume-header">
        <div class="header-content">
            <h1 class="resume-title">Jherson Aguto</h1>
            <p class="resume-subtitle">Full Stack Developer & Software Engineer</p>
        </div>
        <div class="header-actions">
            <a href="https://jhersonaguto.dev" class="btn-portfolio">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path><polyline points="9 22 9 12 15 12 15 22"></polyline></svg>
                Back to Portfolio
            </a>
            @if (_activeResume != null)
            {
                <a href="@_activeResume.FileUrl" target="_blank" rel="noopener noreferrer" download="Jherson_Aguto_Resume.pdf" class="btn-download">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path><polyline points="7 10 12 15 17 10"></polyline><line x1="12" y1="15" x2="12" y2="3"></line></svg>
                    Download PDF
                </a>
            }
        </div>
    </div>

    <div class="resume-content-wrapper">
        @if (_isLoading)
        {
            <div class="loading-state">
                <div class="spinner"></div>
                <p>Loading resume viewer...</p>
            </div>
        }
        else if (_activeResume != null)
        {
            <div class="pdf-viewer-card">
                <!-- Fallback info for mobile browsers or if embedding is blocked -->
                <div class="pdf-fallback-info">
                    <p>💡 Viewing on mobile? If the viewer doesn't load, you can <a href="@_activeResume.FileUrl" target="_blank" rel="noopener noreferrer">view directly in your browser</a> or click "Download PDF" above.</p>
                </div>
                
                <div class="iframe-container">
                    <iframe src="@($"{_activeResume.FileUrl}#toolbar=0&navpanes=0&scrollbar=1")" 
                            type="application/pdf"
                            title="Jherson Aguto Resume Viewer"
                            frameborder="0">
                    </iframe>
                </div>
            </div>
        }
        else
        {
            <div class="empty-state-card">
                <div class="empty-icon-wrapper">
                    <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path><polyline points="14 2 14 8 20 8"></polyline><line x1="9" y1="15" x2="15" y2="15"></line><line x1="9" y1="19" x2="15" y2="19"></line><line x1="9" y1="11" x2="11" y2="11"></line></svg>
                </div>
                <h2>No Resume Active</h2>
                <p>The administrator has not uploaded or activated a resume file yet. Please check back later or visit the main portfolio site.</p>
                <a href="https://jhersonaguto.dev" class="btn-portfolio-large">
                    Go to Portfolio Home
                </a>
            </div>
        }
    </div>
</div>

<style>
    .resume-page-container {
        min-height: 100vh;
        background-color: #0b0f19;
        color: #f3f4f6;
        font-family: 'Inter', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
        padding: 2rem;
        box-sizing: border-box;
        display: flex;
        flex-direction: column;
        gap: 1.5rem;
    }

    .resume-header {
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
        display: flex;
        justify-content: space-between;
        align-items: center;
        flex-wrap: wrap;
        gap: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding-bottom: 1.5rem;
    }

    .resume-title {
        font-size: 2.25rem;
        font-weight: 800;
        margin: 0;
        letter-spacing: -0.025em;
        background: linear-gradient(135deg, #6366f1 0%, #a855f7 100%);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .resume-subtitle {
        font-size: 1rem;
        color: #9ca3af;
        margin: 0.25rem 0 0 0;
    }

    .header-actions {
        display: flex;
        gap: 1rem;
    }

    .btn-portfolio, .btn-download, .btn-portfolio-large {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.625rem 1.25rem;
        border-radius: 0.5rem;
        font-weight: 600;
        font-size: 0.875rem;
        text-decoration: none;
        transition: all 0.2s ease;
        cursor: pointer;
    }

    .btn-portfolio {
        background-color: rgba(255, 255, 255, 0.05);
        color: #e5e7eb;
        border: 1px solid rgba(255, 255, 255, 0.1);
    }

    .btn-portfolio:hover {
        background-color: rgba(255, 255, 255, 0.1);
        border-color: rgba(255, 255, 255, 0.2);
    }

    .btn-download {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: #ffffff;
        border: none;
        box-shadow: 0 4px 12px rgba(79, 70, 229, 0.3);
    }

    .btn-download:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.4);
    }

    .resume-content-wrapper {
        max-width: 1100px;
        margin: 0 auto;
        width: 100%;
        flex-grow: 1;
        display: flex;
        flex-direction: column;
    }

    .loading-state {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding: 5rem;
        color: #9ca3af;
        gap: 1rem;
    }

    .spinner {
        width: 40px;
        height: 40px;
        border: 4px solid rgba(99, 102, 241, 0.1);
        border-top-color: #6366f1;
        border-radius: 50%;
        animation: spin 1s infinite linear;
    }

    .pdf-viewer-card {
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3), 0 10px 10px -5px rgba(0, 0, 0, 0.2);
    }

    .pdf-fallback-info {
        padding: 0.75rem 1.25rem;
        background-color: rgba(99, 102, 241, 0.08);
        border-bottom: 1px solid rgba(99, 102, 241, 0.15);
        font-size: 0.85rem;
        color: #c7d2fe;
        text-align: center;
    }

    .pdf-fallback-info a {
        color: #818cf8;
        text-decoration: underline;
        font-weight: 600;
    }

    .iframe-container {
        position: relative;
        width: 100%;
        height: calc(100vh - 180px);
        min-height: 650px;
        background-color: #1f2937;
    }

    .iframe-container iframe {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        border: none;
    }

    .empty-state-card {
        background: rgba(17, 24, 39, 0.6);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        border: 1px solid rgba(255, 255, 255, 0.05);
        border-radius: 1rem;
        padding: 4rem 2rem;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        max-width: 600px;
        margin: 4rem auto;
        box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.3);
    }

    .empty-icon-wrapper {
        color: #4f46e5;
        background-color: rgba(79, 70, 229, 0.1);
        padding: 1.25rem;
        border-radius: 50%;
        margin-bottom: 1.5rem;
        display: inline-flex;
    }

    .empty-state-card h2 {
        font-size: 1.5rem;
        font-weight: 700;
        margin: 0 0 0.5rem 0;
        color: #f3f4f6;
    }

    .empty-state-card p {
        color: #9ca3af;
        font-size: 0.95rem;
        max-width: 400px;
        line-height: 1.5;
        margin: 0 0 2rem 0;
    }

    .btn-portfolio-large {
        background: linear-gradient(135deg, #4f46e5 0%, #7c3aed 100%);
        color: #ffffff;
        border: none;
        font-size: 0.95rem;
        padding: 0.75rem 1.75rem;
    }

    .btn-portfolio-large:hover {
        transform: translateY(-1px);
        box-shadow: 0 6px 16px rgba(79, 70, 229, 0.4);
    }

    .icon {
        flex-shrink: 0;
    }

    @@keyframes spin {
        to { transform: rotate(360deg); }
    }

    @@media (max-width: 640px) {
        .resume-page-container {
            padding: 1rem;
        }
        .resume-header {
            flex-direction: column;
            align-items: flex-start;
            gap: 1rem;
        }
        .header-actions {
            width: 100%;
        }
        .btn-portfolio, .btn-download {
            flex-grow: 1;
            justify-content: center;
        }
        .iframe-container {
            height: calc(100vh - 240px);
            min-height: 450px;
        }
    }
</style>

@code {
    private BlazorPortfolio.Models.ResumeFile? _activeResume;
    private bool _isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _activeResume = await Svc.GetActiveResumeAsync();
            if (_activeResume != null && _activeResume.FileUrl.Contains("raw.githubusercontent.com"))
            {
                // Convert raw.githubusercontent.com/{owner}/{repo}/{branch}/{path}
                // to cdn.jsdelivr.net/gh/{owner}/{repo}@{branch}/{path}
                _activeResume.FileUrl = _activeResume.FileUrl
                    .Replace("raw.githubusercontent.com/", "cdn.jsdelivr.net/gh/")
                    .Replace("/main/", "@main/")
                    .Replace("/master/", "@master/");
            }
        }
        catch (Exception)
        {
            // Fail gracefully
            _activeResume = null;
        }
        finally
        {
            _isLoading = false;
        }
    }
}
