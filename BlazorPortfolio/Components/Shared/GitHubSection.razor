@rendermode InteractiveServer
@inject GitHubService GitHub
@inject CacheService Cache
@inject IJSRuntime JS

@if (!string.IsNullOrWhiteSpace(GitHubUsername))
{
    <section class="section alt" id="github">
        <div class="container">
            <div class="section-header">
                <span class="section-tag">Open Source</span>
                <h2>GitHub</h2>
            </div>

            @if (ghProfile is not null)
            {
                <div class="gh-banner anim-slide">
                    @if (!string.IsNullOrEmpty(ghProfile.AvatarUrl))
                    {
                        <img src="@ghProfile.AvatarUrl" alt="@ghProfile.Name" class="gh-banner-avatar" />
                    }
                    <div class="gh-banner-info">
                        <div class="gh-banner-name">@ghProfile.Name</div>
                        @if (!string.IsNullOrEmpty(ghProfile.Bio))
                        {
                            <div class="gh-banner-bio">@ghProfile.Bio</div>
                        }
                        <div class="gh-banner-stats">
                            <span class="gh-stat-chip">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/></svg>
                                @ghProfile.PublicRepos public repos
                            </span>
                            <span class="gh-stat-chip">
                                <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M2 5.5a3.5 3.5 0 1 1 5.898 2.549 5.508 5.508 0 0 1 3.034 4.084.75.75 0 1 1-1.482.235 4 4 0 0 0-7.9 0 .75.75 0 0 1-1.482-.236A5.507 5.507 0 0 1 3.102 8.05 3.493 3.493 0 0 1 2 5.5ZM11 4a3.001 3.001 0 0 1 2.22 5.018 5.01 5.01 0 0 1 2.56 3.012.749.749 0 0 1-.885.954.752.752 0 0 1-.549-.514 3.507 3.507 0 0 0-2.522-2.372.75.75 0 0 1-.574-.73v-.352a.75.75 0 0 1 .416-.672A1.5 1.5 0 0 0 11 5.5.75.75 0 0 1 11 4Zm-5.5-.5a2 2 0 1 0-.001 3.999A2 2 0 0 0 5.5 3.5Z"/></svg>
                                @ghProfile.Followers followers
                            </span>
                            @if (ghContribTotal > 0)
                            {
                                <span class="gh-stat-chip highlight">
                                    <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"/></svg>
                                    @ghContribTotal contributions this year
                                </span>
                            }
                        </div>
                    </div>
                    <div class="gh-banner-actions">
                        <a href="@("https://github.com/" + GitHubUsername)" target="_blank" class="gh-view-profile">
                            <svg width="15" height="15" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
                            View on GitHub
                        </a>
                    </div>
                </div>
            }

            <div class="gh-tabs">
                <button class="gh-tab @(repoTab == "pinned" ? "active" : "")" @onclick='() => SetTab("pinned")'>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
                    Pinned
                </button>
                <button class="gh-tab @(repoTab == "all" ? "active" : "")" @onclick='() => SetTab("all")'>
                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/></svg>
                    All Public Repos
                    @if (allRepos is not null) { <span class="gh-tab-count">@allRepos.Count</span> }
                </button>
            </div>

            @{
                var displayRepos = repoTab == "all" ? allRepos : pinnedRepos;
                var isLoading    = repoTab == "all" ? allRepos is null : pinnedRepos is null;
            }
            @if (isLoading)
            {
                <div class="gh-repos-skeleton">
                    @for (int i = 0; i < 6; i++) { <div class="skeleton gh-repo-skeleton"></div> }
                </div>
            }
            else if (displayRepos is { Count: 0 })
            {
                <div class="gh-empty-state">
                    <svg width="32" height="32" viewBox="0 0 16 16" fill="currentColor" style="color:var(--text-muted)"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/></svg>
                    <p>No public repositories found for <strong>@GitHubUsername</strong>.</p>
                    <a href="@("https://github.com/" + GitHubUsername)" target="_blank" class="gh-view-profile" style="margin-top:.5rem">View on GitHub ↗</a>
                </div>
            }
            else if (displayRepos is not null)
            {
                <div class="gh-repos-grid">
                    @{ int ci = 0; }
                    @foreach (var repo in displayRepos)
                    {
                        var cd = $"d{(ci % 6) + 1}"; ci++;
                        <div class="gh-repo-card anim-scale @cd">
                            <div class="gh-repo-header">
                                <div class="gh-repo-name-row">
                                    <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor" class="gh-repo-icon"><path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/></svg>
                                    <a href="@repo.Url" target="_blank" class="gh-repo-title">@repo.Name</a>
                                </div>
                                <div class="gh-repo-actions">
                                    @if (!string.IsNullOrEmpty(repo.HomepageUrl))
                                    {
                                        <a href="@repo.HomepageUrl" target="_blank" class="gh-icon-btn" title="Live demo">
                                            <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M3.75 2h3.5a.75.75 0 0 1 0 1.5h-3.5a.25.25 0 0 0-.25.25v8.5c0 .138.112.25.25.25h8.5a.25.25 0 0 0 .25-.25v-3.5a.75.75 0 0 1 1.5 0v3.5A1.75 1.75 0 0 1 12.25 14h-8.5A1.75 1.75 0 0 1 2 12.25v-8.5C2 2.784 2.784 2 3.75 2Zm6.854-1h4.146a.25.25 0 0 1 .25.25v4.146a.25.25 0 0 1-.427.177L13.03 4.03 9.28 7.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.75-3.75-1.543-1.543A.25.25 0 0 1 10.604 1Z"/></svg>
                                        </a>
                                    }
                                    <a href="@repo.Url" target="_blank" class="gh-icon-btn" title="View on GitHub">
                                        <svg width="13" height="13" viewBox="0 0 16 16" fill="currentColor"><path d="M8 0c4.42 0 8 3.58 8 8a8.013 8.013 0 0 1-5.45 7.59c-.4.08-.55-.17-.55-.38 0-.27.01-1.13.01-2.2 0-.75-.25-1.23-.54-1.48 1.78-.2 3.65-.88 3.65-3.95 0-.88-.31-1.59-.82-2.15.08-.2.36-1.02-.08-2.12 0 0-.67-.22-2.2.82-.64-.18-1.32-.27-2-.27-.68 0-1.36.09-2 .27-1.53-1.03-2.2-.82-2.2-.82-.44 1.1-.16 1.92-.08 2.12-.51.56-.82 1.28-.82 2.15 0 3.06 1.86 3.75 3.64 3.95-.23.2-.44.55-.51 1.07-.46.21-1.61.55-2.33-.66-.15-.24-.6-.83-1.23-.82-.67.01-.27.38.01.53.34.19.73.9.82 1.13.16.45.68 1.31 2.69.94 0 .67.01 1.3.01 1.49 0 .21-.15.45-.55.38A7.995 7.995 0 0 1 0 8c0-4.42 3.58-8 8-8Z"/></svg>
                                    </a>
                                </div>
                            </div>
                            <p class="gh-repo-desc">@(string.IsNullOrEmpty(repo.Description) ? "No description." : repo.Description)</p>
                            @if (repo.Topics.Count > 0)
                            {
                                <div class="gh-topics">
                                    @foreach (var topic in repo.Topics.Take(4))
                                    {
                                        <span class="gh-topic">@topic</span>
                                    }
                                </div>
                            }
                            <div class="gh-repo-footer">
                                @if (!string.IsNullOrEmpty(repo.PrimaryLanguage))
                                {
                                    <span class="gh-lang">
                                        <span class="gh-lang-dot" style="background:@repo.LanguageColor"></span>
                                        @repo.PrimaryLanguage
                                    </span>
                                }
                                @if (repo.Stars > 0)
                                {
                                    <span class="gh-meta-item">
                                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/></svg>
                                        @repo.Stars
                                    </span>
                                }
                                @if (repo.Forks > 0)
                                {
                                    <span class="gh-meta-item">
                                        <svg width="12" height="12" viewBox="0 0 16 16" fill="currentColor"><path d="M5 5.372v.878c0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75v-.878a2.25 2.25 0 1 1 1.5 0v.878a2.25 2.25 0 0 1-2.25 2.25h-1.5v2.128a2.251 2.251 0 1 1-1.5 0V8.5h-1.5A2.25 2.25 0 0 1 3.5 6.25v-.878a2.25 2.25 0 1 1 1.5 0ZM5 3.25a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Zm6.75.75a.75.75 0 1 0 0-1.5.75.75 0 0 0 0 1.5Zm-3 8.75a.75.75 0 1 0-1.5 0 .75.75 0 0 0 1.5 0Z"/></svg>
                                        @repo.Forks
                                    </span>
                                }
                                @if (!string.IsNullOrEmpty(repo.UpdatedAt) && DateTime.TryParse(repo.UpdatedAt, out var updAt))
                                {
                                    <span class="gh-meta-item gh-updated">@TimeAgo(updAt)</span>
                                }
                            </div>
                        </div>
                    }
                </div>
            }

            @if (ghContribWeeks is { Count: > 0 })
            {
                <div class="gh-contrib-wrap">
                    <div class="gh-contrib-top">
                        <div>
                            <div class="gh-contrib-title">
                                <svg width="16" height="16" viewBox="0 0 16 16" fill="currentColor"><path d="M11.93 8.5a4.002 4.002 0 0 1-7.86 0H.75a.75.75 0 0 1 0-1.5h3.32a4.002 4.002 0 0 1 7.86 0h3.32a.75.75 0 0 1 0 1.5Zm-1.43-.75a2.5 2.5 0 1 0-5 0 2.5 2.5 0 0 0 5 0Z"/></svg>
                                @ghContribTotal contributions in the last year
                            </div>
                            <div class="gh-contrib-sub">Coding activity across all public repositories</div>
                        </div>
                        <div class="gh-streaks">
                            @if (longestStreak > 0)
                            {
                                <div class="gh-streak">
                                    <span class="gh-streak-val">@longestStreak</span>
                                    <span class="gh-streak-label">🔥 Longest streak</span>
                                </div>
                            }
                            @if (currentStreak > 0)
                            {
                                <div class="gh-streak">
                                    <span class="gh-streak-val">@currentStreak</span>
                                    <span class="gh-streak-label">⚡ Current streak</span>
                                </div>
                            }
                        </div>
                    </div>
                    <div class="gh-graph-scroll">
                        <div class="gh-graph-inner">
                            <div class="gh-months" style="--week-count:@ghContribWeeks.Count">
                                @foreach (var (label, col) in monthLabels)
                                {
                                    <span class="gh-month-lbl" style="grid-column:@col">@label</span>
                                }
                            </div>
                            <div class="gh-graph-body">
                                <div class="gh-day-lbls">
                                    <span></span><span>Mon</span><span></span>
                                    <span>Wed</span><span></span><span>Fri</span><span></span>
                                </div>
                                <canvas id="contrib-canvas" class="gh-contrib-canvas" aria-label="GitHub contribution graph"></canvas>
                            </div>
                        </div>
                    </div>
                    <div class="gh-legend">
                        <span>Less</span>
                        <span class="gh-cell" style="background:rgba(255,255,255,.04)"></span>
                        <span class="gh-cell" style="background:#0e4429"></span>
                        <span class="gh-cell" style="background:#006d32"></span>
                        <span class="gh-cell" style="background:#26a641"></span>
                        <span class="gh-cell" style="background:#39d353"></span>
                        <span>More</span>
                    </div>
                </div>
            }
        </div>
    </section>
}

@code {
    [Parameter, EditorRequired] public string GitHubUsername { get; set; } = string.Empty;

    GitHubProfile? ghProfile;
    List<GitHubPinnedRepo>? pinnedRepos;
    List<GitHubPinnedRepo>? allRepos;
    List<GitHubContributionWeek> ghContribWeeks = [];
    int ghContribTotal;
    int longestStreak;
    int currentStreak;
    string repoTab = "pinned";
    List<(string Label, int Col)> monthLabels = [];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || string.IsNullOrWhiteSpace(GitHubUsername)) return;

        ghProfile = await Cache.GetAsync<GitHubProfile>(CacheService.Keys.GitHubProfile);
        if (ghProfile is null)
        {
            ghProfile = await GitHub.GetProfileAsync(GitHubUsername);
            if (ghProfile is not null) await Cache.SetAsync(CacheService.Keys.GitHubProfile, ghProfile);
        }
        StateHasChanged();

        pinnedRepos = await Cache.GetAsync<List<GitHubPinnedRepo>>(CacheService.Keys.GitHubPinned);
        if (pinnedRepos is null)
        {
            pinnedRepos = await GitHub.GetPinnedReposAsync(GitHubUsername);
            await Cache.SetAsync(CacheService.Keys.GitHubPinned, pinnedRepos);
        }
        StateHasChanged();

        ghContribWeeks = await Cache.GetAsync<List<GitHubContributionWeek>>(CacheService.Keys.GitHubContributions) ?? [];
        ghContribTotal = await Cache.GetAsync<int>(CacheService.Keys.GitHubContribTotal);
        if (ghContribWeeks.Count == 0)
        {
            var (weeks, total) = await GitHub.GetContributionsAsync(GitHubUsername);
            ghContribWeeks = weeks; ghContribTotal = total;
            await Cache.SetAsync(CacheService.Keys.GitHubContributions, weeks);
            await Cache.SetAsync(CacheService.Keys.GitHubContribTotal, total);
        }

        if (ghContribWeeks.Count > 0) { ComputeStreaks(); BuildMonthLabels(); }
        StateHasChanged();
        if (ghContribWeeks.Count > 0)
            await JS.InvokeVoidAsync("renderContribGraph", "contrib-canvas", SerializeWeeks());
    }

    async Task SetTab(string tab)
    {
        repoTab = tab;
        if (tab == "all" && allRepos is null)
        {
            allRepos = await Cache.GetAsync<List<GitHubPinnedRepo>>(CacheService.Keys.GitHubAllRepos);
            if (allRepos is null)
            {
                allRepos = await GitHub.GetAllPublicReposAsync(GitHubUsername);
                await Cache.SetAsync(CacheService.Keys.GitHubAllRepos, allRepos);
            }
        }
    }

    void ComputeStreaks()
    {
        var allDays = ghContribWeeks.SelectMany(w => w.Days).OrderBy(d => d.Date).ToList();
        int run = 0, lng = 0, cur = 0;
        var today = DateTime.UtcNow.Date;
        foreach (var day in allDays) { if (day.Count > 0) run++; else run = 0; if (run > lng) lng = run; }
        foreach (var day in allDays.AsEnumerable().Reverse())
        {
            if (!DateTime.TryParse(day.Date, out var dt)) break;
            if (dt.Date > today) continue;
            if (day.Count > 0) cur++; else break;
        }
        longestStreak = lng; currentStreak = cur;
    }

    void BuildMonthLabels()
    {
        monthLabels = []; string? last = null; int col = 1;
        foreach (var week in ghContribWeeks)
        {
            var first = week.Days.FirstOrDefault();
            if (first is not null && DateTime.TryParse(first.Date, out var dt))
            {
                var m = dt.ToString("MMM");
                if (m != last) { monthLabels.Add((m, col)); last = m; }
            }
            col++;
        }
    }

    // Serialize only what the canvas renderer needs — avoids passing full C# objects via JS interop
    object SerializeWeeks() =>
        ghContribWeeks.Select(w => new
        {
            days = w.Days.Select(d => new
            {
                dayOfWeek = d.DayOfWeek,
                date      = d.Date,
                count     = d.Count,
                color     = d.Color
            })
        });

    static string TimeAgo(DateTime dt)
    {
        var d = DateTime.UtcNow - dt;
        if (d.TotalDays < 1)   return "today";
        if (d.TotalDays < 7)   return $"{(int)d.TotalDays}d ago";
        if (d.TotalDays < 30)  return $"{(int)(d.TotalDays / 7)}w ago";
        if (d.TotalDays < 365) return $"{(int)(d.TotalDays / 30)}mo ago";
        return $"{(int)(d.TotalDays / 365)}y ago";
    }
}
