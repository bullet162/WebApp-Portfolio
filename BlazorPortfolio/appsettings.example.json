{
  "_comment": "Copy this file to appsettings.json for local development. In production, set all values as environment variables using the double-underscore convention (e.g., Admin__Username, ConnectionStrings__DefaultConnection).",
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Database=portfolio;Username=postgres;Password=yourpassword"
  },
  "Admin": {
    "Username": "your-admin-username",
    "Password": "your-admin-password"
  },
  "GitHub": {
    "Token": "your-github-token"
  },
  "Resend": {
    "ApiKey": "your-resend-api-key"
  },
  "KeepAlive": {
    "BaseUrl": "https://your-app.onrender.com/health",
    "IntervalMinutes": 10
  },
  "Cloudinary": {
    "CloudName": "your-cloud-name",
    "ApiKey": "your-api-key",
    "ApiSecret": "your-api-secret"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
